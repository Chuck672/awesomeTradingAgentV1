{
  "name": "awesome-chart-v3",
  "version": "3.1.0-beta",
  "author": "QuantLogicLab",
  "description": "Awesome Chart Application",
  "private": true,
  "main": "main.js",
  "build": {
    "appId": "com.quantlogiclab.awesomechartv3",
    "productName": "AwesomeChartV3",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/main",
        "to": "backend"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "scripts": {
    "dev": "next dev -p 3123",
    "build": "next build",
    "export": "cross-env ELECTRON=true next build",
    "electron:start": "electron .",
    "electron:build": "npm run export && electron-builder",
    "start": "next start -p 3123",
    "lint": "eslint",
    "dist": "npm run build && electron-builder --win",
    "electron": "wait-on http://localhost:3000 && electron ."
  },
  "build": {
    "appId": "com.awesome.chart",
    "productName": "AwesomeChartV3",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "main.js",
      "out/**/*"
    ],
    "win": {
      "target": [
        "portable",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fancy-canvas": "^2.1.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  }
}
